# Azure Document Intelligence (optional) 
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=

# LLM Provider: "ollama" | "openai" 
LLM_PROVIDER=ollama

# OpenAI / OpenRouter 
# Dùng OpenRouter: set OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Dùng OpenAI gốc: để trống OPENAI_BASE_URL
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FAST_MODEL=gpt-4o-mini

# Ollama 
# Để trống: auto-detect WSL host IP
# Trong Docker: dùng http://host.docker.internal:11434
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_FAST_MODEL=qwen3.5:2b-q4_K_M
